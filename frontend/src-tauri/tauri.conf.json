{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gestor Financeiro",
  "version": "0.1.0",
  "identifier": "com.gestor-financeiro",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Gestor Financeiro",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "additionalBrowserArgs": "--enable-gpu-rasterization --enable-oop-rasterization --enable-zero-copy"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "headerImage": "nsis/installer-header.bmp",
        "sidebarImage": "nsis/installer-sidebar.bmp",
        "installMode": "currentUser",
        "languages": ["PortugueseBR"]
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
